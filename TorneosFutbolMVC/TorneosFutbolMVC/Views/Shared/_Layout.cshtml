<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TorneosFutbolMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TorneosFutbolMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">

            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Torneo"
                   asp-action="Index">

                   Torneos de Fútbol
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menu">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="menu">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Torneo"
                               asp-action="Index">

                                Torneos

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Torneo"
                               asp-action="Create">

                                Nuevo Torneo

                            </a>

                        </li>

                    </ul>

                    <span class="navbar-text text-white">

                        Sistema de Gestión Deportiva

                    </span>

                </div>

            </div>

        </nav>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">

                <div class="alert alert-success alert-dismissible fade show">

                    @TempData["Success"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>

            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">

                <div class="alert alert-danger alert-dismissible fade show">

                    @TempData["Error"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>

            </div>
        }
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TorneosFutbolMVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
