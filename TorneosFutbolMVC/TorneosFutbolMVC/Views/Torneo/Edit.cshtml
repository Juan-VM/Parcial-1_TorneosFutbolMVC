@model TorneosFutbolMVC.Models.Torneo

<div class="container mt-4">

    <div class="card">

        <div class="card-header">
            <h3>Editar Torneo</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <input asp-for="Id" hidden />
                <input asp-for="Activo" hidden />
                <input asp-for="CreadoEn" hidden />

                <div class="mb-3">

                    <label asp-for="Nombre"></label>

                    <input asp-for="Nombre"
                           class="form-control" />

                    <span asp-validation-for="Nombre"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Edicion"></label>

                    <input asp-for="Edicion"
                           class="form-control" />

                    <span asp-validation-for="Edicion"
                          class="text-danger"></span>

                </div>

                <button type="submit"
                        class="btn btn-primary">
                    Actualizar
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Volver
                </a>

            </form>

        </div>

    </div>

</div>